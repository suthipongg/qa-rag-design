# --- LLM Configuration ---
# Get your free Gemini API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite
CONTEXT_WINDOW=5

# --- Embedding Configuration ---
# Options: "bge-m3" (local, no cost) | "gemini" (API, free tier)
EMBEDDING_PROVIDER=bge-m3
EMBEDDING_MODEL=BAAI/bge-m3 # BAAI/bge-m3 or gemini-embedding-2-preview

# --- Qdrant Configuration ---
# Dashboard available at: http://localhost:6333/dashboard
QDRANT_HOST=localhost
QDRANT_PORT=6333
EMBED_COLLECTION=knowledge_base

# --- Database ---
DATABASE_URL=sqlite:///./app_data.db

# --- RAG Settings ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
RELEVANCE_THRESHOLD=0.3